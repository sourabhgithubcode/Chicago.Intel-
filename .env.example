# Supabase — frontend (public safe)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps / Places — frontend (domain-restrict in Google Cloud!)
VITE_GOOGLE_MAPS_KEY=your-key
VITE_GOOGLE_PLACES_KEY=your-key

# Mapbox — frontend
VITE_MAPBOX_TOKEN=your-token

# Optional paid APIs — frontend
VITE_RENTCAST_KEY=
VITE_HOWLOUD_KEY=

# ─────────────────────────────────────
# Backend only — set in Render cron job
# NEVER expose these to the frontend
# ─────────────────────────────────────

# Supabase service role (full DB access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Data source API keys
CENSUS_API_KEY=your-census-key
CHICAGO_DATA_TOKEN=your-socrata-app-token
COOK_COUNTY_API_KEY=optional-key-for-assessor
