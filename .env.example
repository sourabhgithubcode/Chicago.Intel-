# ============================================================
# Chicago.Intel — Environment Variables (example)
# Copy this file to .env and fill in real values.
# NEVER commit .env. Only .env.example is tracked.
# ============================================================

# ---------- Frontend (Vite) ----------
# VITE_ prefix = exposed to the browser. Anon keys only, never service role.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Domain-restricted in Google Cloud Console before production
VITE_GOOGLE_MAPS_KEY=
VITE_GOOGLE_PLACES_KEY=

VITE_MAPBOX_TOKEN=

# Optional (V3)
VITE_RENTCAST_KEY=
VITE_HOWLOUD_KEY=

# ---------- Data Pipeline (Python, server-side only) ----------
# No VITE_ prefix — never bundled into the browser.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Census API — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Chicago Data Portal (Socrata) — https://data.cityofchicago.org/profile/app_tokens
CHICAGO_DATA_PORTAL_APP_TOKEN=

# ---------- Analytics ----------
VITE_GOATCOUNTER_CODE=
