# Supabase — frontend (public safe)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps / Places — frontend (domain-restrict in Google Cloud!)
VITE_GOOGLE_MAPS_KEY=your-key
VITE_GOOGLE_PLACES_KEY=your-key

# Mapbox — frontend
VITE_MAPBOX_TOKEN=your-token

# Optional paid APIs — frontend (V3+)
VITE_RENTCAST_KEY=
VITE_HOWLOUD_KEY=
VITE_AIRNOW_KEY=
VITE_YELP_KEY=

# Monitoring & analytics — frontend (V3+)
VITE_SENTRY_DSN=
VITE_GOATCOUNTER_URL=

# ─────────────────────────────────────
# Backend only — set in Render cron job
# NEVER expose these to the frontend
# ─────────────────────────────────────

# Supabase service role (full DB access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Data source API keys
CENSUS_API_KEY=your-census-key
CHICAGO_DATA_TOKEN=your-socrata-app-token
COOK_COUNTY_API_KEY=optional-key-for-assessor

# Bronze layer storage (raw JSONL archive of every API response)
# BRONZE_BACKEND: "local" (default, writes to data/bronze/) or "r2"
BRONZE_BACKEND=local
BRONZE_LOCAL_ROOT=data/bronze

# R2 / S3 settings — only required when BRONZE_BACKEND=r2
BRONZE_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
